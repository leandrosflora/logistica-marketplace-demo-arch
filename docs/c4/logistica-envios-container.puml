@startuml
' Rendered by .github/workflows/render-diagrams.yml using C4-PlantUML.
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Logística Envios - C4 Nível 2 - Containers (implementação atual)

Person(buyer, "Comprador")
Person(operator, "Operação/Suporte")
System_Ext(paymentProvider, "Provedor de pagamento externo/simulado", "Dependência pendente para consumir payment.commands")
System_Ext(carrierProvider, "Transportadoras externas", "Correios, last-mile e parceiros")

System_Boundary(platform, "Logística Envios Platform") {
  Container(bff, "Marketplace BFF", ".NET 8", "Agrega dados para o frontend.")
  Container(productSearch, "Product Search Service", ".NET 8", "Busca produtos ativos em read model Postgres.")
  Container(checkout, "Checkout Service", ".NET 8", "Cria, consulta e confirma sessões de checkout.")
  Container(promise, "Shipping Promise Service", ".NET 8", "Calcula prazo, disponibilidade, modalidade e preço.")
  Container(catalog, "Product Catalog Service", ".NET 8", "Expõe atributos logísticos do SKU.")
  Container(inventory, "Inventory Service", ".NET 8", "Disponibilidade, reserva, confirmação e liberação de estoque.")
  Container(fc, "Fulfillment Center Service", ".NET 8", "Capacidade, cutoff, operação e reservas de CDs.")
  Container(routing, "Routing Service", ".NET 8", "Calcula rotas e mantém grafo logístico.")
  Container(carrier, "Carrier Service", ".NET 8", "Gerencia carriers, service levels, lanes e disponibilidade.")
  Container(pricing, "Shipping Pricing Service", ".NET 8", "Calcula frete, quotes e rate cards.")
  Container(order, "Order Service", ".NET 8", "Mantém pedidos e orquestra saga por outbox/Kafka.")
  Container(shipment, "Shipment Service", ".NET 8", "Cria shipment, pacotes, etiqueta e comandos para carrier.")
  Container(tracking, "Tracking Service", ".NET 8", "Mantém linha do tempo e status de entrega.")
  Container(notification, "Notification Service", ".NET 8", "Planeja e envia notificações Email/SMS/Push.")
  Container(orderVisibility, "Order Visibility Service", ".NET 8", "Consumidor passivo da jornada; mantém read model de status/timeline e serve a tela Order Monitor via REST + SignalR.")

  ContainerDb(kafka, "Kafka", "Event Streaming", "Eventos implementados, comandos internos e tópicos pendentes da saga.")
  ContainerDb(postgres, "Postgres / RDS", "Relational DB", "Schemas/connections por microservice conforme código.")
  ContainerDb(redis, "Redis", "Cache", "Usado por Shipping Promise, Catalog, Routing, Carrier e Pricing.")
  ContainerDb(labelStorage, "Label Storage", "FileSystem local", "Armazena/expõe etiquetas de shipment no ambiente demo.")
}

Rel(buyer, bff, "Usa")
Rel(operator, orderVisibility, "Consulta status/timeline de pedidos e realtime via REST + SignalR (tela Order Monitor)")
Rel(bff, productSearch, "Busca produtos")
Rel(bff, checkout, "Cria/consulta/confirma checkout")
Rel(checkout, promise, "Solicita cotação HTTP")
Rel(promise, catalog, "Consulta atributos")
Rel(promise, inventory, "Consulta estoque")
Rel(promise, fc, "Consulta capacidade")
Rel(promise, routing, "Calcula rota")
Rel(promise, carrier, "Consulta restrições/disponibilidade")
Rel(promise, pricing, "Calcula preço")

Rel(checkout, kafka, "Publica checkout.shipping.quote.requested / checkout.confirmed; consome shipping.promise.calculated")
Rel(promise, kafka, "Consome checkout.shipping.quote.requested; publica shipping.promise.calculated")
Rel(order, kafka, "Consome checkout/inventory/fulfillment/shipment/status; publica order.created e comandos")
Rel(inventory, kafka, "Consome inventory.commands; publica eventos de reserva")
Rel(fc, kafka, "Consome fulfillment.commands; publica eventos de capacidade")
Rel(shipment, kafka, "Consome order.created/shipment.commands; publica shipment.created")
Rel(tracking, kafka, "Consome shipment.created; publica shipment.status.updated")
Rel(notification, kafka, "Consome eventos configurados para notificação")
Rel(orderVisibility, kafka, "Consome checkout.confirmed/order.created e eventos de inventory/fulfillment/payment/shipment/tracking; não publica")
Rel(order, paymentProvider, "Emite payment.commands; consumidor real não implementado")

Rel(carrier, carrierProvider, "Consulta disponibilidade")
Rel(shipment, carrierProvider, "Registra shipment e gera etiqueta")
Rel(tracking, carrierProvider, "Recebe eventos de rastreio")

Rel(productSearch, postgres, "Lê read model de products")
Rel(checkout, postgres, "Lê/grava CheckoutDb")
Rel(promise, postgres, "Lê/grava ShippingPromiseDb")
Rel(catalog, postgres, "Lê/grava Product Catalog")
Rel(inventory, postgres, "Lê/grava InventoryDb")
Rel(fc, postgres, "Lê/grava FulfillmentDb")
Rel(routing, postgres, "Lê/grava RoutingDb quando não mock")
Rel(carrier, postgres, "Lê/grava CarrierDb")
Rel(pricing, postgres, "Lê/grava PricingDb")
Rel(order, postgres, "Lê/grava OrderDb")
Rel(shipment, postgres, "Lê/grava ShipmentDb")
Rel(tracking, postgres, "Lê/grava TrackingDb")
Rel(notification, postgres, "Lê/grava NotificationDb")
Rel(orderVisibility, postgres, "Lê/grava order_visibility (order_journey, order_journey_events)")

Rel(promise, redis, "Cache shipping-promise")
Rel(catalog, redis, "Cache de atributos")
Rel(routing, redis, "Cache de rotas")
Rel(carrier, redis, "Cache de carrier")
Rel(pricing, redis, "Cache de pricing")
Rel(shipment, labelStorage, "Gera URLs temporárias de etiqueta")

@enduml
