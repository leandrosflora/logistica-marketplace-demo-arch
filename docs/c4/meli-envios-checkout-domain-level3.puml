@startuml
' C4 Nível 3 - domínio Checkout e Promise Assíncrona
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Meli Envios - C4 Nível 3 - Domínio Checkout e Promise Assíncrona
caption Fluxo de cotação de frete assíncrona via Kafka entre CheckoutService e ShippingPromiseService.

Person(buyer, "Comprador", "Inicia o processo de compra no marketplace")

System_Boundary(platform, "Meli Envios Platform") {
  Component(web, "Marketplace Web", "ASP.NET Core Razor", "Canal web do marketplace")
  Component(bff, "MarketplaceWeb.Bff", ".NET 8 BFF", "API orientada à experiência web, propaga x-correlation-id e x-client-id")

  Component_Boundary(checkoutBound, "Checkout Service (.NET 8)") {
    Component(checkoutController, "CheckoutController", "ASP.NET Core Controller", "Expõe POST /v1/checkouts e POST /v1/checkouts/{id}/confirm")
    Component(checkoutApp, "CheckoutApplicationService", "Application Service", "Orquestra criação e confirmação do checkout")
    Component(checkoutDomain, "Checkout (Aggregate)", "Domain Entity", "Checkout com status, itens e promessa associada")
    Component(checkoutRepo, "CheckoutRepository", "Infrastructure", "Persistência do checkout em Postgres")
    Component(checkoutProducer, "KafkaCheckoutProducer", "Infrastructure", "Publica checkout.shipping.quote.requested")
    Component(checkoutConsumer, "KafkaPromiseConsumer", "Infrastructure", "Consome shipping.promise.calculated e projeta no checkout")
    Component(checkoutIdempotency, "IdempotencyMiddleware", "Infrastructure", "Deduplicação via x-idempotency-key em Redis")
  }

  Component(kafka, "Kafka Cluster", "Kafka", "Backbone assíncrono")
  Component(quoteTopic, "Topic: checkout.shipping.quote.requested", "Kafka Topic", "Solicitação de cotação de frete")
  Component(promiseTopic, "Topic: shipping.promise.calculated", "Kafka Topic", "Resultado da promessa calculada")

  Component_Boundary(promiseBound, "Shipping Promise Service (.NET 8)") {
    Component(promiseConsumer, "KafkaQuoteConsumer", "Infrastructure", "Consome checkout.shipping.quote.requested")
    Component(promiseApp, "ShippingPromiseCalculator", "Application Service", "Orquestra consultas síncronas e calcula promessa")
    Component(promiseDomain, "ShippingPromise (Aggregate)", "Domain Entity", "Promessa calculada com prazo, carrier e custo")
    Component(promiseProducer, "KafkaPromisePublisher", "Infrastructure", "Publica shipping.promise.calculated")
  }
}

Rel(buyer, web, "Seleciona produto e inicia checkout", "HTTPS")
Rel(web, bff, "GET /api/web/v1/checkout", "HTTPS/JSON")
Rel(bff, checkoutController, "POST /v1/checkouts", "HTTP/JSON\nx-correlation-id\nx-client-id\nx-idempotency-key")
Rel(checkoutController, checkoutIdempotency, "Verifica idempotência", "Redis")
Rel(checkoutController, checkoutApp, "CreateCheckout(command)")
Rel(checkoutApp, checkoutDomain, "Cria entidade Checkout")
Rel(checkoutApp, checkoutRepo, "Persiste checkout", "Postgres")
Rel(checkoutApp, checkoutProducer, "Publica evento de cotação")
Rel(checkoutProducer, quoteTopic, "Publica", "Kafka")
Rel(quoteTopic, promiseConsumer, "Consome", "Kafka consumer group: shipping-promise-service")
Rel(promiseConsumer, promiseApp, "CalculatePromise(request)")
Rel(promiseApp, promiseDomain, "Cria ShippingPromise")
Rel(promiseApp, promiseProducer, "Publica promessa calculada")
Rel(promiseProducer, promiseTopic, "Publica", "Kafka")
Rel(promiseTopic, checkoutConsumer, "Consome", "Kafka consumer group: checkout-service")
Rel(checkoutConsumer, checkoutRepo, "Atualiza checkout com promessa", "Postgres")

note right of quoteTopic
Payload inclui: checkoutId, buyerId, sellerId,
destination, items[].
checkoutId permite correlação assíncrona.
end note

note right of promiseTopic
Payload inclui: checkoutId, promiseId, mode,
carrier, estimatedDeliveryDate, cost, currency.
checkoutId é obrigatório para correlação.
end note

@enduml
